import os
import requests
import argparse

# 기본 경로 설정 (2번 코드와 동일)
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
VIDEO_DIR = os.path.join(SCRIPT_DIR, "video")
os.makedirs(VIDEO_DIR, exist_ok=True)

# 백엔드 서버 주소 (팀원에게 받은 주소로 변경하세요)
SERVER_BASE_URL = "http://localhost:8080" # 예: http://192.168.1.100:3000

def download_pending_video():
    print("📡 서버에 대기 중인 영상이 있는지 확인합니다...")
    
    try:
        # 1. 대기 목록 조회 (timeout을 60으로 변경)
        list_res = requests.get(f"{SERVER_BASE_URL}/api/videos/pending", timeout=60)
        
        if list_res.status_code != 200:
            print(f"❌ 목록 조회 실패 (상태 코드: {list_res.status_code})")
            return None

        pending_videos = list_res.json() # 서버가 ["TS.mp4"] 형태로 준다고 가정
        
        if not pending_videos:
            print("💤 현재 서버에 대기 중인 새 영상이 없습니다.")
            return None
            
        target_video = pending_videos[0] # 가장 첫 번째 영상을 타겟으로 잡음
        print(f"🎯 타겟 영상 발견: {target_video}")
        
        # 2. 영상 다운로드
        download_url = f"{SERVER_BASE_URL}/api/videos/download/{target_video}"
        print(f"📥 다운로드 시작: {download_url}")
        
        # 2. 영상 다운로드 (용량이 클 수 있으니 120초 정도로 넉넉하게)
        dl_res = requests.get(download_url, stream=True, timeout=120)
        if dl_res.status_code == 200:
            save_path = os.path.join(VIDEO_DIR, target_video)
            with open(save_path, 'wb') as f:
                for chunk in dl_res.iter_content(chunk_size=8192):
                    f.write(chunk)
            print(f"✅ 다운로드 완료! 저장 위치: {save_path}")
            return target_video
        else:
            print(f"❌ 다운로드 실패 (상태 코드: {dl_res.status_code})")
            return None
            
    except requests.exceptions.RequestException as e:
        print(f"🚨 서버 통신 에러: {e}")
        return None

if __name__ == "__main__":
    download_pending_video()